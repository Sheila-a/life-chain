PORT=4000
NODE_ENV=development
JWT_SECRET=change-this-secret

# PostgreSQL (Render will inject this automatically when linked)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifechain

# Optional: comma-separated list of allowed frontend origins
# Example: https://life-chain-frontend.onrender.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Hedera
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_HCS_TOPIC_ID=

# AWS KMS signing for resource updates and bookings
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_KMS_KEY_ID=
AWS_KMS_SIGNING_ALGORITHM=ECDSA_SHA_256

# Master key for wrapping vault AES keys (must be 32+ chars)
VAULT_MASTER_KEY=replace-with-strong-master-key-32-chars
